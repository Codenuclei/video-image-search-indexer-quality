# Copy to .env and fill in.

DATABASE_URL=postgresql+asyncpg://drivefaceindexer:drivefaceindexer@localhost:5432/drivefaceindexer

# Drive Connector
DRIVE_CONNECTOR_BASE_URL=http://localhost:3000
DRIVE_CONNECTOR_API_KEY=dck_your_connector_key_here

# Gemini File Search (managed multimodal RAG) — get key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-2
GEMINI_FILE_SEARCH_STORE_DISPLAY_NAME=drive-connector-shared

# Auto-index Drive → Gemini
AUTO_INDEX_ENABLED=false
AUTO_INDEX_INTERVAL_SECONDS=300

TEMP_DIR=./data/tmp
THUMBNAIL_DIR=./data/thumbnails

# YouTube downloads (yt-dlp) — required on Railway / headless servers.
# YouTube returns "Sign in to confirm you're not a bot" without cookies.
# Export cookies for youtube.com in Netscape format (browser extension e.g. "Get cookies.txt LOCALLY",
# or: yt-dlp --cookies-from-browser chrome --cookies cookies.txt --skip-download "https://www.youtube.com").
# Then either:
#   1) Put the file on the Railway volume and set the path:
YTDLP_COOKIES_FILE=
# YOUTUBE_COOKIES_FILE=   # alias of YTDLP_COOKIES_FILE
#   2) Or paste the full Netscape file contents into an env var (written to temp at startup):
# YTDLP_COOKIES=
# YOUTUBE_COOKIES=        # alias of YTDLP_COOKIES

# Video indexing (ffmpeg + VTT + Gemini VLM — no Docker sidecar)
VIDEO_INDEXING_ENABLED=true
# Shared team library on Railway: mount a volume at /data and set VIDEO_CACHE_DIR=/data/videos
VIDEO_CACHE_DIR=./data/videos
VIDEO_FRAME_INTERVAL_SECONDS=1.0
VIDEO_MAX_SAMPLE_FRAMES=300
VIDEO_MAX_GEMINI_FRAMES=12
VIDEO_VLM_ENRICH=true
# Parallel video indexing (same pipeline per file; does not restart in-flight videos).
# InsightFace shares a process lock — 3–4 is usually enough on 24 vCPU; higher rarely helps.
VIDEO_INDEX_MAX_PARALLEL=4
# Prefer smaller pending files; claim window = free_slots × multiplier
INDEX_PREFER_SMALL_FILES=true
INDEX_CLAIM_WINDOW_MULTIPLIER=40
VIDEO_INDEX_STALL_SECONDS=900
# Parallel image indexing (face detect + embed per file).
# On Railway 24 vCPU / 24 GB, 8–10 keeps both lanes busy without thrashing Gemini.
# Override higher only after watching CPU + Gemini 429s.
IMAGE_INDEX_MAX_PARALLEL=10
# Caption backfill: batch size × parallel batches (e.g. 8×6 = 48 images in flight)
IMAGE_CAPTION_BATCH_SIZE=8
IMAGE_CAPTION_BATCH_PARALLEL=6
IMAGE_EMBED_BACKFILL_PARALLEL=6
MAINTENANCE_BATCHES_PER_TICK=6
# CPU thread pool (0 = all cores); search + decode parallelism
CPU_THREAD_POOL_SIZE=0
SEARCH_VARIANT_MAX_PARALLEL=0
SEARCH_LLM_BATCH_PARALLEL=0

# Gemini client-side concurrency (tune per https://ai.google.dev/gemini-api/docs/rate-limits)
# Embedding 2: ~40k RPM global on paid tier — 24 concurrent is safe.
# Flash VLM + File Search uploads: keep lower.
GEMINI_EMBED_MAX_CONCURRENT=24
GEMINI_VLM_MAX_CONCURRENT=6
GEMINI_UPLOAD_MAX_CONCURRENT=4

# Vector search quality (Gemini Embedding 2 + Qdrant)
QDRANT_COLLECTION=dfi_video_frames
QDRANT_IMAGES_COLLECTION=dfi_images
GEMINI_VIDEO_RESULT_LIMIT=30
GEMINI_VIDEO_MIN_SCORE=0.25
GEMINI_IMAGE_RESULT_LIMIT=30
GEMINI_IMAGE_MIN_SCORE=0.25

# Free Google reverse image search (SOME-1HING hosted API + scrape fallback).
# Thumbnails must be publicly reachable — set PUBLIC_BASE_URL to the Railway backend.
GOOGLE_REVERSE_API_URL=https://google-reverse-image-api.vercel.app/reverse
PUBLIC_BASE_URL=

# Official Google reverse image search = Cloud Vision Web Detection (weak for people ID).
# Prefer Apify Google Lens for identity-grade results.
GOOGLE_VISION_API_KEY=

# Apify Google Lens (borderline/google-lens) — AI Mode + exact/visual matches.
# Token: https://console.apify.com/account/integrations
APIFY_TOKEN=
APIFY_GOOGLE_LENS_ACTOR=borderline/google-lens

# Optional Cohesivity Exa people enrichment → LinkedIn (from .cohesivity or env).
COHESIVITY_APPLICATION_KEY=
COHESIVITY_EXA_BASE_URL=https://cohesivity.ai/edge/exa-api

# Optional paid Google Lens fallback
SERPAPI_KEY=

# Append-only body/clothing re-identification layer (body_signatures table).
REID_ENABLED=true
REID_MIN_FACE_AREA_FRACTION=0.015
REID_MIN_BODY_COVERAGE=0.55
REID_BODY_MATCH_THRESHOLD=0.60

# Qwen3-VL sidecar — GPU only (not available on Railway). Leave disabled in cloud.
QWEN_VLM_ENABLED=false
QWEN_VLM_BASE_URL=http://127.0.0.1:8003
QWEN_VLM_MODEL=Qwen/Qwen3-VL-8B-Instruct

# Legacy Fennec sidecar (optional, disabled by default)
FENNEC_ENABLED=false
